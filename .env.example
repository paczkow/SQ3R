# LLM API Configuration
# Copy this file to .env and fill in your values

# Base URL for the LLM API (OpenAI-compatible chat completions endpoint)
# Examples:
#   OpenRouter: https://openrouter.ai/api/v1
#   OpenAI: https://api.openai.com/v1
#   Anthropic (via proxy): https://api.anthropic.com/v1
#   LM Studio (local): http://localhost:1234/v1
#   Ollama (local): http://localhost:11434/v1
LLM_BASE_URL=https://openrouter.ai/api/v1

# API key for the LLM provider
# Note: Local providers (LM Studio, Ollama) don't require a real key - use any non-empty value
LLM_API_KEY=your-api-key-here

# Model identifier
# Examples:
#   OpenRouter: google/gemini-2.0-flash-exp, anthropic/claude-3.5-sonnet
#   OpenAI: gpt-4o, gpt-4-turbo
#   LM Studio: The model name shown in LM Studio's server UI (e.g., "llama-3.1-8b-instruct")
#   Ollama: The model tag (e.g., "llama3.1:8b")
LLM_MODEL=google/gemini-2.0-flash-exp

# ──────────────────────────────────────────────────────────────────────────────
# Local LLM Setup Examples
# ──────────────────────────────────────────────────────────────────────────────

# LM Studio (https://lmstudio.ai/)
# 1. Download and install LM Studio
# 2. Download a model
# 3. Start the local server (Developer → Start Server)
# 4. Use these settings:
#
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=llama-3.1-8b-instruct

# Ollama (https://ollama.ai/)
# 1. Install Ollama: https://ollama.ai/download
# 2. Pull a model: ollama pull llama3.1:8b
# 3. Ensure Ollama is running (it auto-starts on install)
# 4. Use these settings:
#
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=llama3.1:8b

# ──────────────────────────────────────────────────────────────────────────────
# Note: This tool requires structured JSON output support (response_format with
# json_schema). Not all local models support this feature. If you get errors,
# try a newer/larger model or use a cloud provider.
# ──────────────────────────────────────────────────────────────────────────────
